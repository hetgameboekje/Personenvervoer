@{
    ViewData["Title"] = "Deelnemers";
}

<h1>Deelnemers</h1>

<div class="mb-3">
    <button class="btn btn-primary" onclick="openCreateModal()">
        <i class="bi bi-plus-lg"></i> Nieuwe deelnemer
    </button>
</div>

<div id="alertContainer"></div>

<table class="table table-striped table-hover align-middle" id="membersTable">
    <thead class="table-dark">
        <tr>
            <th>Naam</th>
            <th>E-mail</th>
            <th>Telefoon</th>
            <th>Adres</th>
            <th>Acties</th>
        </tr>
    </thead>
    <tbody id="membersBody">
        <tr><td colspan="5" class="text-center">Laden...</td></tr>
    </tbody>
</table>

<!-- Create/Edit Modal -->
<div class="modal fade" id="memberModal" tabindex="-1" aria-labelledby="memberModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="memberModalLabel">Deelnemer</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Sluiten"></button>
            </div>
            <div class="modal-body">
                <form id="memberForm">
                    <input type="hidden" id="memberId" />
                    <div class="mb-3">
                        <label for="memberName" class="form-label">Naam <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" id="memberName" required />
                    </div>
                    <div class="mb-3">
                        <label for="memberEmail" class="form-label">E-mail</label>
                        <input type="email" class="form-control" id="memberEmail" />
                    </div>
                    <div class="mb-3">
                        <label for="memberPhone" class="form-label">Telefoon</label>
                        <input type="text" class="form-control" id="memberPhone" />
                    </div>
                    <div class="mb-3">
                        <label for="memberAddress" class="form-label">Adres</label>
                        <input type="text" class="form-control" id="memberAddress" />
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label for="memberLatitude" class="form-label">Breedtegraad</label>
                            <input type="number" step="any" class="form-control" id="memberLatitude" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label for="memberLongitude" class="form-label">Lengtegraad</label>
                            <input type="number" step="any" class="form-control" id="memberLongitude" />
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Annuleren</button>
                <button type="button" class="btn btn-primary" onclick="saveMember()">Opslaan</button>
            </div>
        </div>
    </div>
</div>

<!-- Delete Confirm Modal -->
<div class="modal fade" id="deleteModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-sm">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Verwijderen bevestigen</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Sluiten"></button>
            </div>
            <div class="modal-body">
                Weet u zeker dat u deze deelnemer wilt verwijderen?
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Annuleren</button>
                <button type="button" class="btn btn-danger" id="confirmDeleteBtn">Verwijderen</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    const memberModal = new bootstrap.Modal(document.getElementById('memberModal'));
    const deleteModal = new bootstrap.Modal(document.getElementById('deleteModal'));

    async function loadMembers() {
        try {
            const res = await fetch('/api/members');
            const data = await res.json();
            const tbody = document.getElementById('membersBody');
            if (!data.length) {
                tbody.innerHTML = '<tr><td colspan="5" class="text-center text-muted">Geen deelnemers gevonden.</td></tr>';
                return;
            }
            tbody.innerHTML = data.map(m => `
                <tr>
                    <td>${escHtml(m.name)}</td>
                    <td>${escHtml(m.email ?? '')}</td>
                    <td>${escHtml(m.phone ?? '')}</td>
                    <td>${escHtml(m.address ?? '')}</td>
                    <td>
                        <button class="btn btn-sm btn-outline-primary me-1" onclick="openEditModal('${m.id}')">Bewerken</button>
                        <button class="btn btn-sm btn-outline-danger" onclick="openDeleteModal('${m.id}')">Verwijderen</button>
                    </td>
                </tr>`).join('');
        } catch (e) {
            showAlert('Fout bij laden van deelnemers.', 'danger');
        }
    }

    function openCreateModal() {
        document.getElementById('memberModalLabel').textContent = 'Nieuwe deelnemer';
        document.getElementById('memberForm').reset();
        document.getElementById('memberId').value = '';
        memberModal.show();
    }

    async function openEditModal(id) {
        try {
            const res = await fetch(`/api/members/${id}`);
            if (!res.ok) throw new Error();
            const m = await res.json();
            document.getElementById('memberModalLabel').textContent = 'Deelnemer bewerken';
            document.getElementById('memberId').value = m.id;
            document.getElementById('memberName').value = m.name;
            document.getElementById('memberEmail').value = m.email ?? '';
            document.getElementById('memberPhone').value = m.phone ?? '';
            document.getElementById('memberAddress').value = m.address ?? '';
            document.getElementById('memberLatitude').value = m.latitude ?? '';
            document.getElementById('memberLongitude').value = m.longitude ?? '';
            memberModal.show();
        } catch (e) {
            showAlert('Fout bij ophalen deelnemer.', 'danger');
        }
    }

    async function saveMember() {
        const id = document.getElementById('memberId').value;
        const name = document.getElementById('memberName').value.trim();
        if (!name) { showAlert('Naam is verplicht.', 'warning'); return; }
        const body = {
            name,
            email: document.getElementById('memberEmail').value || null,
            phone: document.getElementById('memberPhone').value || null,
            address: document.getElementById('memberAddress').value || null,
            latitude: parseDecimal(document.getElementById('memberLatitude').value),
            longitude: parseDecimal(document.getElementById('memberLongitude').value),
        };
        try {
            const url = id ? `/api/members/${id}` : '/api/members';
            const method = id ? 'PUT' : 'POST';
            const res = await fetch(url, { method, headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(body) });
            if (!res.ok) throw new Error();
            memberModal.hide();
            showAlert(id ? 'Deelnemer bijgewerkt.' : 'Deelnemer aangemaakt.', 'success');
            loadMembers();
        } catch (e) {
            showAlert('Fout bij opslaan.', 'danger');
        }
    }

    function openDeleteModal(id) {
        document.getElementById('confirmDeleteBtn').onclick = () => deleteMember(id);
        deleteModal.show();
    }

    async function deleteMember(id) {
        try {
            const res = await fetch(`/api/members/${id}`, { method: 'DELETE' });
            if (!res.ok) throw new Error();
            deleteModal.hide();
            showAlert('Deelnemer verwijderd.', 'success');
            loadMembers();
        } catch (e) {
            showAlert('Fout bij verwijderen.', 'danger');
        }
    }

    function showAlert(msg, type) {
        const div = document.createElement('div');
        div.className = `alert alert-${type} alert-dismissible fade show`;
        div.innerHTML = `${escHtml(msg)}<button type="button" class="btn-close" data-bs-dismiss="alert"></button>`;
        const container = document.getElementById('alertContainer');
        container.prepend(div);
        setTimeout(() => div.remove(), 4000);
    }

    function escHtml(s) {
        return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
    }

    function parseDecimal(val) {
        const n = parseFloat(val);
        return isNaN(n) ? null : n;
    }

    loadMembers();
</script>
}
