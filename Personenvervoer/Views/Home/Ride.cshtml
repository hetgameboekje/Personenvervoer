@{
    ViewData["Title"] = "Ritten";
}

<h1>Ritten</h1>

<div class="mb-3">
    <button class="btn btn-primary" onclick="openCreateModal()">
        <i class="bi bi-plus-lg"></i> Nieuwe rit
    </button>
</div>

<div id="alertContainer"></div>

<table class="table table-striped table-hover align-middle">
    <thead class="table-dark">
        <tr>
            <th>Rittype</th>
            <th>Ritpatroon</th>
            <th>Eindlocatie</th>
            <th>Voertuig</th>
            <th>Rijtijd</th>
            <th>Acties</th>
        </tr>
    </thead>
    <tbody id="ridesBody">
        <tr><td colspan="6" class="text-center">Laden...</td></tr>
    </tbody>
</table>

<!-- Create/Edit Modal -->
<div class="modal fade" id="rideModal" tabindex="-1" aria-labelledby="rideModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="rideModalLabel">Rit</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Sluiten"></button>
            </div>
            <div class="modal-body">
                <form id="rideForm">
                    <input type="hidden" id="rideId" />
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label for="rideRidepattern" class="form-label">Ritpatroon</label>
                            <select class="form-select" id="rideRidepattern">
                                <option value="">— Geen —</option>
                            </select>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label for="rideVehicle" class="form-label">Voertuig</label>
                            <select class="form-select" id="rideVehicle">
                                <option value="">— Geen —</option>
                            </select>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label for="rideEndLocation" class="form-label">Eindlocatie</label>
                            <select class="form-select" id="rideEndLocation">
                                <option value="">— Geen —</option>
                            </select>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label for="rideType" class="form-label">Rittype</label>
                            <select class="form-select" id="rideType">
                                <option value="a_to_b">A naar B</option>
                                <option value="b_to_a">B naar A</option>
                                <option value="round_trip">Heen en terug</option>
                            </select>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <label for="rideMaxBoardingTime" class="form-label">Max instaptijd</label>
                            <input type="datetime-local" class="form-control" id="rideMaxBoardingTime" />
                        </div>
                        <div class="col-md-4 mb-3">
                            <label for="rideLocationTime" class="form-label">Locatietijd</label>
                            <input type="datetime-local" class="form-control" id="rideLocationTime" />
                        </div>
                        <div class="col-md-4 mb-3">
                            <label for="rideRideTime" class="form-label">Rijtijd</label>
                            <input type="datetime-local" class="form-control" id="rideRideTime" />
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Annuleren</button>
                <button type="button" class="btn btn-primary" onclick="saveRide()">Opslaan</button>
            </div>
        </div>
    </div>
</div>

<!-- Delete Confirm Modal -->
<div class="modal fade" id="deleteModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-sm">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Verwijderen bevestigen</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Sluiten"></button>
            </div>
            <div class="modal-body">
                Weet u zeker dat u deze rit wilt verwijderen?
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Annuleren</button>
                <button type="button" class="btn btn-danger" id="confirmDeleteBtn">Verwijderen</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    const rideModal = new bootstrap.Modal(document.getElementById('rideModal'));
    const deleteModal = new bootstrap.Modal(document.getElementById('deleteModal'));

    async function fetchJson(url) {
        const res = await fetch(url);
        if (!res.ok) {
            console.warn(`Request to ${url} failed with status ${res.status}`);
            return [];
        }
        return res.json();
    }

    async function populateSelects(selectedRidepatternId, selectedVehicleId, selectedLocationId) {
        const [ridepatterns, vehicles, locations] = await Promise.all([
            fetchJson('/api/ridepatterns'),
            fetchJson('/api/vehicles'),
            fetchJson('/api/locations'),
        ]);

        document.getElementById('rideRidepattern').innerHTML =
            '<option value="">— Geen —</option>' +
            ridepatterns.map(rp => `<option value="${rp.id}"${rp.id === selectedRidepatternId ? ' selected' : ''}>${escHtml(rp.member?.name ?? rp.id)}</option>`).join('');

        document.getElementById('rideVehicle').innerHTML =
            '<option value="">— Geen —</option>' +
            vehicles.map(v => `<option value="${v.id}"${v.id === selectedVehicleId ? ' selected' : ''}>${escHtml(v.licensePlate)} (${escHtml(v.vehicleType)})</option>`).join('');

        document.getElementById('rideEndLocation').innerHTML =
            '<option value="">— Geen —</option>' +
            locations.map(l => `<option value="${l.id}"${l.id === selectedLocationId ? ' selected' : ''}>${escHtml(l.name)}</option>`).join('');
    }

    function toLocalDatetimeInput(isoStr) {
        if (!isoStr) return '';
        const d = new Date(isoStr);
        const pad = n => String(n).padStart(2, '0');
        return `${d.getFullYear()}-${pad(d.getMonth()+1)}-${pad(d.getDate())}T${pad(d.getHours())}:${pad(d.getMinutes())}`;
    }

    async function loadRides() {
        try {
            const res = await fetch('/api/rides');
            if (!res.ok) throw new Error(`HTTP ${res.status}`);
            const data = await res.json();
            const tbody = document.getElementById('ridesBody');
            if (!data.length) {
                tbody.innerHTML = '<tr><td colspan="6" class="text-center text-muted">Geen ritten gevonden.</td></tr>';
                return;
            }
            tbody.innerHTML = data.map(r => `
                <tr>
                    <td>${escHtml(r.rideType)}</td>
                    <td>${escHtml(r.ridepattern?.member?.name ?? '—')}</td>
                    <td>${escHtml(r.endLocation?.name ?? '—')}</td>
                    <td>${escHtml(r.vehicle?.licensePlate ?? '—')}</td>
                    <td>${r.rideTime ? new Date(r.rideTime).toLocaleString('nl-NL') : '—'}</td>
                    <td>
                        <button class="btn btn-sm btn-outline-primary me-1" onclick="openEditModal('${r.id}')">Bewerken</button>
                        <button class="btn btn-sm btn-outline-danger" onclick="openDeleteModal('${r.id}')">Verwijderen</button>
                    </td>
                </tr>`).join('');
        } catch (e) {
            showAlert('Fout bij laden van ritten.', 'danger');
        }
    }

    async function openCreateModal() {
        document.getElementById('rideModalLabel').textContent = 'Nieuwe rit';
        document.getElementById('rideForm').reset();
        document.getElementById('rideId').value = '';
        await populateSelects(null, null, null);
        rideModal.show();
    }

    async function openEditModal(id) {
        try {
            const res = await fetch(`/api/rides/${id}`);
            if (!res.ok) throw new Error();
            const r = await res.json();
            document.getElementById('rideModalLabel').textContent = 'Rit bewerken';
            document.getElementById('rideId').value = r.id;
            document.getElementById('rideType').value = r.rideType;
            document.getElementById('rideMaxBoardingTime').value = toLocalDatetimeInput(r.maxBoardingTime);
            document.getElementById('rideLocationTime').value = toLocalDatetimeInput(r.locationTime);
            document.getElementById('rideRideTime').value = toLocalDatetimeInput(r.rideTime);
            await populateSelects(r.ridepatternId, r.vehicleId, r.endLocationId);
            rideModal.show();
        } catch (e) {
            showAlert('Fout bij ophalen rit.', 'danger');
        }
    }

    async function saveRide() {
        const id = document.getElementById('rideId').value;
        const body = {
            ridepatternId: document.getElementById('rideRidepattern').value || null,
            vehicleId: document.getElementById('rideVehicle').value || null,
            endLocationId: document.getElementById('rideEndLocation').value || null,
            rideType: document.getElementById('rideType').value,
            maxBoardingTime: document.getElementById('rideMaxBoardingTime').value || null,
            locationTime: document.getElementById('rideLocationTime').value || null,
            rideTime: document.getElementById('rideRideTime').value || null,
        };
        try {
            const url = id ? `/api/rides/${id}` : '/api/rides';
            const method = id ? 'PUT' : 'POST';
            const res = await fetch(url, { method, headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(body) });
            if (!res.ok) throw new Error();
            rideModal.hide();
            showAlert(id ? 'Rit bijgewerkt.' : 'Rit aangemaakt.', 'success');
            loadRides();
        } catch (e) {
            showAlert('Fout bij opslaan.', 'danger');
        }
    }

    function openDeleteModal(id) {
        document.getElementById('confirmDeleteBtn').onclick = () => deleteRide(id);
        deleteModal.show();
    }

    async function deleteRide(id) {
        try {
            const res = await fetch(`/api/rides/${id}`, { method: 'DELETE' });
            if (!res.ok) throw new Error();
            deleteModal.hide();
            showAlert('Rit verwijderd.', 'success');
            loadRides();
        } catch (e) {
            showAlert('Fout bij verwijderen.', 'danger');
        }
    }

    function showAlert(msg, type) {
        const div = document.createElement('div');
        div.className = `alert alert-${type} alert-dismissible fade show`;
        div.innerHTML = `${escHtml(msg)}<button type="button" class="btn-close" data-bs-dismiss="alert"></button>`;
        const container = document.getElementById('alertContainer');
        container.prepend(div);
        setTimeout(() => div.remove(), 4000);
    }

    function escHtml(s) {
        return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
    }

    loadRides();
</script>
}
