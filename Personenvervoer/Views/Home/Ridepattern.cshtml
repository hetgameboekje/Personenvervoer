@{
    ViewData["Title"] = "Ritpatronen";
}

<h1>Ritpatronen</h1>

<div class="mb-3">
    <button class="btn btn-primary" onclick="openCreateModal()">
        <i class="bi bi-plus-lg"></i> Nieuw ritpatroon
    </button>
</div>

<div id="alertContainer"></div>

<table class="table table-striped table-hover align-middle">
    <thead class="table-dark">
        <tr>
            <th>Deelnemer</th>
            <th>Rolstoel</th>
            <th>Rang</th>
            <th>Acties</th>
        </tr>
    </thead>
    <tbody id="ridepatternsBody">
        <tr><td colspan="4" class="text-center">Laden...</td></tr>
    </tbody>
</table>

<!-- Create/Edit Modal -->
<div class="modal fade" id="ridepatternModal" tabindex="-1" aria-labelledby="ridepatternModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="ridepatternModalLabel">Ritpatroon</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Sluiten"></button>
            </div>
            <div class="modal-body">
                <form id="ridepatternForm">
                    <input type="hidden" id="ridepatternId" />
                    <div class="mb-3">
                        <label for="ridepatternMember" class="form-label">Deelnemer</label>
                        <select class="form-select" id="ridepatternMember">
                            <option value="">— Geen —</option>
                        </select>
                    </div>
                    <div class="mb-3 form-check">
                        <input type="checkbox" class="form-check-input" id="ridepatternWheelchair" />
                        <label class="form-check-label" for="ridepatternWheelchair">Rolstoelgebruiker</label>
                    </div>
                    <div class="mb-3">
                        <label for="ridepatternRank" class="form-label">Rang</label>
                        <input type="number" class="form-control" id="ridepatternRank" value="0" min="0" />
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Annuleren</button>
                <button type="button" class="btn btn-primary" onclick="saveRidepattern()">Opslaan</button>
            </div>
        </div>
    </div>
</div>

<!-- Delete Confirm Modal -->
<div class="modal fade" id="deleteModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-sm">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Verwijderen bevestigen</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Sluiten"></button>
            </div>
            <div class="modal-body">
                Weet u zeker dat u dit ritpatroon wilt verwijderen?
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Annuleren</button>
                <button type="button" class="btn btn-danger" id="confirmDeleteBtn">Verwijderen</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    const ridepatternModal = new bootstrap.Modal(document.getElementById('ridepatternModal'));
    const deleteModal = new bootstrap.Modal(document.getElementById('deleteModal'));

    async function loadMembers() {
        try {
            const res = await fetch('/api/members');
            if (!res.ok) {
                console.warn(`Failed to load members: HTTP ${res.status}`);
                return [];
            }
            return await res.json();
        } catch (e) {
            console.warn('Failed to load members:', e);
            return [];
        }
    }

    async function populateMemberSelect(selectedId) {
        const members = await loadMembers();
        const sel = document.getElementById('ridepatternMember');
        sel.innerHTML = '<option value="">— Geen —</option>' +
            members.map(m => `<option value="${m.id}"${m.id === selectedId ? ' selected' : ''}>${escHtml(m.name)}</option>`).join('');
    }

    async function loadRidepatterns() {
        try {
            const res = await fetch('/api/ridepatterns');
            const data = await res.json();
            const tbody = document.getElementById('ridepatternsBody');
            if (!data.length) {
                tbody.innerHTML = '<tr><td colspan="4" class="text-center text-muted">Geen ritpatronen gevonden.</td></tr>';
                return;
            }
            tbody.innerHTML = data.map(rp => `
                <tr>
                    <td>${escHtml(rp.member?.name ?? '—')}</td>
                    <td>${rp.isWheelchair ? '<span class="badge bg-info">Ja</span>' : 'Nee'}</td>
                    <td>${rp.rank}</td>
                    <td>
                        <button class="btn btn-sm btn-outline-primary me-1" onclick="openEditModal('${rp.id}')">Bewerken</button>
                        <button class="btn btn-sm btn-outline-danger" onclick="openDeleteModal('${rp.id}')">Verwijderen</button>
                    </td>
                </tr>`).join('');
        } catch (e) {
            showAlert('Fout bij laden van ritpatronen.', 'danger');
        }
    }

    async function openCreateModal() {
        document.getElementById('ridepatternModalLabel').textContent = 'Nieuw ritpatroon';
        document.getElementById('ridepatternForm').reset();
        document.getElementById('ridepatternId').value = '';
        document.getElementById('ridepatternRank').value = '0';
        await populateMemberSelect(null);
        ridepatternModal.show();
    }

    async function openEditModal(id) {
        try {
            const res = await fetch(`/api/ridepatterns/${id}`);
            if (!res.ok) throw new Error();
            const rp = await res.json();
            document.getElementById('ridepatternModalLabel').textContent = 'Ritpatroon bewerken';
            document.getElementById('ridepatternId').value = rp.id;
            document.getElementById('ridepatternWheelchair').checked = rp.isWheelchair;
            document.getElementById('ridepatternRank').value = rp.rank;
            await populateMemberSelect(rp.memberId);
            ridepatternModal.show();
        } catch (e) {
            showAlert('Fout bij ophalen ritpatroon.', 'danger');
        }
    }

    async function saveRidepattern() {
        const id = document.getElementById('ridepatternId').value;
        const memberId = document.getElementById('ridepatternMember').value || null;
        const body = {
            memberId,
            isWheelchair: document.getElementById('ridepatternWheelchair').checked,
            rank: parseInt(document.getElementById('ridepatternRank').value) || 0,
        };
        try {
            const url = id ? `/api/ridepatterns/${id}` : '/api/ridepatterns';
            const method = id ? 'PUT' : 'POST';
            const res = await fetch(url, { method, headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(body) });
            if (!res.ok) throw new Error();
            ridepatternModal.hide();
            showAlert(id ? 'Ritpatroon bijgewerkt.' : 'Ritpatroon aangemaakt.', 'success');
            loadRidepatterns();
        } catch (e) {
            showAlert('Fout bij opslaan.', 'danger');
        }
    }

    function openDeleteModal(id) {
        document.getElementById('confirmDeleteBtn').onclick = () => deleteRidepattern(id);
        deleteModal.show();
    }

    async function deleteRidepattern(id) {
        try {
            const res = await fetch(`/api/ridepatterns/${id}`, { method: 'DELETE' });
            if (!res.ok) throw new Error();
            deleteModal.hide();
            showAlert('Ritpatroon verwijderd.', 'success');
            loadRidepatterns();
        } catch (e) {
            showAlert('Fout bij verwijderen.', 'danger');
        }
    }

    function showAlert(msg, type) {
        const div = document.createElement('div');
        div.className = `alert alert-${type} alert-dismissible fade show`;
        div.innerHTML = `${escHtml(msg)}<button type="button" class="btn-close" data-bs-dismiss="alert"></button>`;
        const container = document.getElementById('alertContainer');
        container.prepend(div);
        setTimeout(() => div.remove(), 4000);
    }

    function escHtml(s) {
        return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
    }

    loadRidepatterns();
</script>
}
